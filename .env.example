# PostgreSQL
POSTGRES_USER=wheimo
POSTGRES_PASSWORD=changeme

# JWT (wheimo-api)
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme-very-long-secret-key-for-jwt-must-be-at-least-256-bits
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=2592000000

# AES encryption for bank credentials (must be identical in api and fetcher)
AES_PASSPHRASE=changeme-aes-passphrase

# Initial admin user (created automatically on first startup)
AUTH_USERNAME=admin@wheimo.com
AUTH_PASSWORD=changeme

# Optional: override API URL for the frontend container (usually not needed)
# API_URL=http://wheimo-api:8080
